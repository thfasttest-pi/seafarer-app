# =============================================================================
# SEAFARER APP — Environment Variables
# Copy to .env and fill values. Never commit .env to git.
# See docs/config.md for full reference.
# =============================================================================

############################################
# 🌍 ENVIRONMENT
############################################

ENVIRONMENT=development
# Options: development | staging | production

DEBUG=true
# Set false in production

LOG_LEVEL=INFO
# Options: DEBUG | INFO | WARNING | ERROR

############################################
# 🔐 TELEGRAM
############################################

BOT_TOKEN=5812759пп
# Required. From @BotFather. Used for: bot, initData HMAC validation

WEBAPP_URL=https://your-miniapp-domain.com
# Full URL of deployed Mini App (https mandatory for TMA)

MINI_APP_URL=https://t.me/your_bot/app
# WebApp URL for bot /start button (same as in BotFather menu button)

TELEGRAM_BOT_USERNAME=your_bot_username
# Without @. Used for deep links, /start menu

############################################
# ⏱ INITDATA VALIDATION
############################################

INIT_DATA_MAX_AGE_MINUTES=60
# Reject initData older than N minutes (auth_date check)

############################################
# 🗄 DATABASE (PostgreSQL + asyncpg)
############################################

DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/seafarer
# Required. Use asyncpg driver (not psycopg2)

# Optional: build URL from parts
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=seafarer
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password

# Connection pool (optional, has defaults)
# DB_POOL_SIZE=20
# DB_MAX_OVERFLOW=10

############################################
# 🔑 SECURITY
############################################

SECRET_KEY=ba86679d554e9d90faabc515c073f9e2ddc5320c4297f15519df330316651ac1
# Required. Min 32 chars. For signing, sessions if needed

ACCESS_TOKEN_EXPIRE_MINUTES=60
# Used if JWT/session tokens are introduced later

############################################
# ⚡ RATE LIMITING
############################################

RATE_LIMIT_REQUESTS=100
# Max requests per window per user

RATE_LIMIT_WINDOW_SECONDS=60
# Window size in seconds

############################################
# 📄 PAGINATION
############################################

PAGINATION_DEFAULT_LIMIT=20
PAGINATION_MAX_LIMIT=50
# Enforce max to prevent unbounded queries

############################################
# 📊 LOGGING
############################################

LOG_JSON=false
# true in production for structured JSON logs

SLOW_QUERY_THRESHOLD_MS=300
# Log queries slower than this

############################################
# 📦 SEARCH / PG
############################################

ENABLE_TRIGRAM=true
# pg_trgm extension for fuzzy search

############################################
# 🏢 RBAC
############################################

DEFAULT_USER_ROLE=seafarer
# Role for new users (first /start or first API call)

############################################
# 🚀 API SERVER
############################################

API_HOST=0.0.0.0
API_PORT=8000

############################################
# 🌐 CORS & DOCS
############################################

ENABLE_DOCS=true
# Swagger at /docs. Set false in production if desired

ENABLE_CORS=true
ALLOWED_ORIGINS=http://localhost:3000,https://your-miniapp-domain.com
# Comma-separated. No wildcard in production.

############################################
# 🧪 DEV TOOLS
############################################

AUTO_RELOAD=true
# Uvicorn --reload equivalent

############################################
# 📱 FRONTEND (Next.js) — use in frontend/.env.local
############################################
# These are NOT read by backend. Copy to frontend/.env.local

# NEXT_PUBLIC_API_URL=http://localhost:8000
# NEXT_PUBLIC_WEBAPP_URL=https://your-miniapp-domain.com
