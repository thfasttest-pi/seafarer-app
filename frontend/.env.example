# =============================================================================
# SEAFARER APP — Frontend Environment Variables
# Copy to frontend/.env.local. NEXT_PUBLIC_* are exposed to the client.
# =============================================================================

# Backend API base URL (no trailing slash)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Optional: for local dev without Telegram — paste initData from Telegram WebApp debug
# (Only use in development, never in production build.)
# NEXT_PUBLIC_DEV_TG_INIT_DATA=query_id=...&user=...&auth_date=...&hash=...
